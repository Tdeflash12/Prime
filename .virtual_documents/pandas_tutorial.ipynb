#Melt and pivot


df = pd.DataFrame({
    "country": ["USA", "USA", "India", "India"],
    "year": [2020, 2021, 2020, 2021],
    "sales": [100, 120, 90, 110],
    "profit": [20, 25, 18, 22],
    "Tax":[12,232,1,232]
})

# Melt DataFrame (Wide Format → Long Format)
melted_df = df.melt(
    id_vars=["country", "year"],      # Columns that remain unchanged (identifiers)
    value_vars=["sales", "profit"],   # Columns to unpivot/melt into rows
    var_name="metrices",              # New column that stores original column names
    value_name="value"                # New column that stores corresponding values
)

print(melted_df)                      # Display the melted DataFrame

# Pivot DataFrame (Long Format → Wide Format)
melted_df.pivot(
    index=["country", "year"],        # Unique combination used as row index
    columns="metrices",               # Values in 'metrices' become new columns
    values="value"                    # Values used to fill the new columns
)


